# Railway deployment — single reference for this host
#
# Copy values into Railway service variables (backend) and Netlify (frontend).
# Do not hardcode these URLs elsewhere in the repo; use env vars only.
#
# Docs: https://docs.railway.app/

# ── Railway project (example — replace with your service URLs) ───────────────

# Backend public URL (Railway → dazzling-smile service)
RAILWAY_BACKEND_URL=https://dazzling-smile-production-1014.up.railway.app

# Frontend (Netlify)
NETLIFY_FRONTEND_URL=https://lumiafricca.netlify.app

# ── Backend env (Railway → Variables) ────────────────────────────────────────

SERVER_ENV=production
PORT=8080

# App URLs — must match your deployed frontend/backend
FRONTEND_URL=${NETLIFY_FRONTEND_URL}
CORS_ORIGINS=${NETLIFY_FRONTEND_URL}
BASE_URL=${RAILWAY_BACKEND_URL}

# MySQL (Railway MySQL plugin — use variable references in Railway UI)
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# DB_NAME=railway

# Redis (Railway Redis plugin)
# REDIS_ENABLED=true
# REDIS_HOST=${{Redis.REDISHOST}}
# REDIS_PORT=6379

# Email: Gmail SMTP is blocked on Railway (:587). Use Resend HTTP API instead.
# RESEND_API_KEY=re_...

# Cloudinary (required in production — local /uploads disk is ephemeral on Railway)
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...

# Paystack
# PAYSTACK_SECRET_KEY=...
# PAYSTACK_PUBLIC_KEY=...

# Swagger in production (optional)
# SWAGGER_ENABLED=true

# ── Frontend env (Netlify → Site settings → Environment variables) ─────────

NEXT_PUBLIC_API_URL=${RAILWAY_BACKEND_URL}

# ── Railway service settings ─────────────────────────────────────────────────

# Root Directory: / (empty — monorepo root Dockerfile)
# Build: Dockerfile at repo root (see /Dockerfile)
# Start: /app/lumi-backend
# Health check: GET /health

# railway.toml at repo root points here; keep host-specific URLs in THIS file only.
