# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=lumi_user
DB_PASSWORD=change-me
DB_NAME=lumi_marketplace

# JWT Configuration — use 32+ random characters in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h

# File Upload
MAX_UPLOAD_SIZE=10485760

# Cloudinary (required in production — ephemeral container filesystem)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — comma-separated production frontend origins
CORS_ORIGINS=http://localhost:3000

# Frontend (password reset + vendor activation links in emails)
FRONTEND_URL=http://localhost:3000

# SMTP (optional — works locally; many PaaS hosts block outbound :587)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Lumi Africa

# Resend HTTP API (recommended for production when SMTP is blocked)
# https://resend.com
RESEND_API_KEY=

# Production on Railway: see ../deploy/railway.env.example

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:3000/payment/callback

# Redis (optional)
REDIS_ENABLED=false
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Swagger UI at /swagger/index.html (off by default in production; set SWAGGER_ENABLED=true)
SWAGGER_ENABLED=false
