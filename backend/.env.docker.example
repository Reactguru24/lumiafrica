# Copy to .env when running the API inside Docker (`docker compose --profile app up`).
# For infra-only Docker (MySQL + Redis) with the API on the host, use these values in .env instead:
#   DB_HOST=127.0.0.1
#   REDIS_ADDR=127.0.0.1:6379

SERVER_PORT=8080
SERVER_ENV=development

DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=lumi_marketplace

JWT_SECRET=change-me-in-development
JWT_EXPIRY=24h

REDIS_ENABLED=true
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
